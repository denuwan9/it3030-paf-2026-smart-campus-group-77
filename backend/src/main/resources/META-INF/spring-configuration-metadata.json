{
  "properties": [
    {
      "name": "app.jwt.secret",
      "type": "java.lang.String",
      "description": "Minimum 32-byte Base64-encoded secret (HS256)."
    },
    {
      "name": "app.jwt.expiration-ms",
      "type": "java.lang.Long",
      "description": "Token validity in milliseconds."
    },
    {
      "name": "app.mail.from",
      "type": "java.lang.String",
      "description": "Default from email address."
    },
    {
      "name": "app.frontend.url",
      "type": "java.lang.String",
      "description": "Frontend URL (used in OAuth2 redirects)."
    },
    {
      "name": "app.cors.allowed-origins",
      "type": "java.lang.String",
      "description": "Comma-separated list of allowed CORS origins."
    }
  ]
}